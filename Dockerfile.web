# Stage 1: Build
FROM node:20-alpine AS build
WORKDIR /app

COPY src/FinanceHub.Web/package*.json ./
RUN npm ci

COPY src/FinanceHub.Web/ .
RUN npm run build -- --configuration production

# Stage 2: Serve with nginx
FROM nginx:alpine
COPY --from=build /app/dist/finance-hub-web/browser /usr/share/nginx/html
COPY src/FinanceHub.Web/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
